# Environment variables declared in this file are automatically loaded by Next.js and Prisma.
# See https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Prisma Database string (SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret using `openssl rand -base64 32` for production
NEXTAUTH_SECRET="your-nextauth-secret"

# GitHub OAuth Provider Credentials
# Create an OAuth app at https://github.com/settings/developers
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"
